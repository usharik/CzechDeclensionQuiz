<resources>
    <!-- NOTE: AppTheme is now defined in values/themes.xml, values-night/themes.xml, etc. -->

    <style name="CommonTextEdit" parent="android:Widget">
    </style>

    <style name="WordTextEdit" parent="CommonTextEdit">
        <item name="android:layout_marginStart">@dimen/spacing_xs</item>
        <item name="android:layout_marginTop">@dimen/spacing_xs</item>
        <item name="android:background">@drawable/rounded_rect_gray</item>
        <item name="android:textAppearance">@style/TextAppearance.App.Body</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textSize">@dimen/draggable_font_size</item>
        <item name="android:paddingStart">@dimen/spacing_sm</item>
        <item name="android:paddingEnd">@dimen/spacing_sm</item>
        <item name="android:paddingTop">@dimen/spacing_xs</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
    </style>

    <style name="HeaderTextView" parent="CommonTextEdit">
        <item name="android:background">@drawable/rect</item>
        <item name="android:textAppearance">@style/TextAppearance.App.Label</item>
        <item name="android:textColor">@color/colorOnSurfaceVariant</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/static_font_size</item>
        <item name="android:paddingStart">@dimen/spacing_xxs</item>
        <item name="android:paddingEnd">@dimen/spacing_xxs</item>
    </style>

    <style name="RowCaseHeaderText" parent="HeaderTextView">
        <item name="android:textAppearance">@style/TextAppearance.App.Label</item>
    </style>

    <style name="RowCaseValueText" parent="CommonTextEdit">
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">@dimen/draggable_font_size</item>
    </style>

    <style name="WordRadioButton" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:button">@null</item>
        <item name="android:background">@drawable/radio_button_background</item>
        <item name="android:textAppearance">@style/TextAppearance.App.Label</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textAlignment">center</item>
        <item name="android:layout_margin">@dimen/spacing_xxs</item>
        <item name="android:paddingStart">@dimen/spacing_sm</item>
        <item name="android:paddingEnd">@dimen/spacing_sm</item>
        <item name="android:paddingTop">@dimen/spacing_xs</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
        <item name="android:textSize">@dimen/text_size_label</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="HandbookRadioButton" parent="WordRadioButton">
        <item name="android:textSize">@dimen/text_size_body</item>
    </style>

    <!-- Typography text appearance styles -->
    <style name="TextAppearance.App.Heading" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">@dimen/text_size_heading</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_size_body</item>
    </style>

    <style name="TextAppearance.App.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_size_label</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_size_small</item>
    </style>

    <!-- Shape appearance styles -->
    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">@dimen/corner_radius_small</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">@dimen/corner_radius_medium</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">@dimen/corner_radius_large</item>
    </style>

    <style name="Widget.App.SectionCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorSurfaceVariant</item>
        <item name="cardCornerRadius">@dimen/corner_radius_large</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/colorStroke</item>
        <item name="strokeWidth">@dimen/stroke_width_thin</item>
    </style>

    <!-- Base button style -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Modern gradient button styles -->
    <style name="Widget.App.Button.Gradient" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textColor">@color/button_text_on_gradient</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">17sp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.App.Button.Gradient.Primary">
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/button_gradient_primary</item>
    </style>

    <style name="Widget.App.Button.Gradient.Secondary">
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/button_gradient_secondary</item>
    </style>

    <style name="Widget.App.Button.Gradient.Accent">
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/button_gradient_accent</item>
    </style>

    <style name="Widget.App.Button.Gradient.Neutral">
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/button_gradient_neutral</item>
    </style>

    <style name="Widget.App.Button.Outlined.Modern" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textColor">@color/button_outline_stroke</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">17sp</item>
        <item name="strokeColor">@color/button_outline_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">16dp</item>
    </style>
</resources>
