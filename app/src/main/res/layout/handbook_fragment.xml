<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="com.usharik.app.R"/>
        <import type="android.view.View"/>

        <variable
                name="viewModel"
                type="com.usharik.app.fragment.HandbookViewModel"/>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/spacing_xxs"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_xxs">

        <com.google.android.material.card.MaterialCardView
                android:id="@+id/selectionCard"
                style="@style/Widget.App.SectionCard"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/detailsBarrier" />

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/genderHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_content"
                android:text="@string/gender_of_noun"
                android:textAppearance="@style/TextAppearance.App.Title"
                android:textColor="@color/colorOnSurface"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Gender of noun"/>

        <RadioGroup
                android:id="@+id/genderGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xxs"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xxs"
                android:orientation="horizontal"
                android:checkedButton="@={viewModel.selectedGender}"
                app:layout_constraintTop_toBottomOf="@+id/genderHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioMasculine"
                    style="@style/HandbookRadioButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/masculine"
                    tools:checked="true"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioNeuter"
                    style="@style/HandbookRadioButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/neuter"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioFeminine"
                    style="@style/HandbookRadioButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feminine"/>

        </RadioGroup>

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/typeHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/type_of_declension"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="@color/colorOnSurface"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/genderGroup"
                tools:text="Type of declension"/>

        <RadioGroup
                android:id="@+id/wordGroupMasculine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xxs"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xxs"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:visibility="@{viewModel.selectedGender == R.id.radioMasculine ? View.VISIBLE : View.GONE}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/typeHeader">

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/pan"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="pán"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/hrad"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="hrad"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/muz"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="muž"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/stroj"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="stroj"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/predseda"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="předseda"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/soudce"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="soudce"/>

        </RadioGroup>

        <RadioGroup
                android:id="@+id/wordGroupNeuter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xxs"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xxs"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:visibility="@{viewModel.selectedGender == R.id.radioNeuter ? View.VISIBLE : View.GONE}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/typeHeader"
                tools:visibility="gone">

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/mesto"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="město"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/more"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="moře"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/kure"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="kuře"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/staveni"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="stavení"/>

        </RadioGroup>

        <RadioGroup
                android:id="@+id/wordGroupFeminine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xxs"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xxs"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:visibility="@{viewModel.selectedGender == R.id.radioFeminine ? View.VISIBLE : View.GONE}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/typeHeader"
                tools:visibility="gone">

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/zena"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="žena"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/ruze"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="růže"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/pisen"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="píseň"/>

            <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/kost"
                    style="@style/HandbookRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="kost"/>

        </RadioGroup>

        <!-- Barrier to position content below all three RadioGroups -->
        <androidx.constraintlayout.widget.Barrier
                android:id="@+id/wordGroupsBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="wordGroupMasculine,wordGroupNeuter,wordGroupFeminine" />

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/otherNounsHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/other_nouns"
                android:textAppearance="@style/TextAppearance.App.Label"
                android:textColor="@color/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/wordGroupsBarrier"
                tools:text="Other nouns: "/>

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/otherNouns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_xxs"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@{viewModel.otherNouns}"
                android:textAppearance="@style/TextAppearance.App.Caption"
                android:textColor="@color/colorOnSurfaceVariant"
                app:layout_constraintStart_toEndOf="@id/otherNounsHeader"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/otherNounsHeader"
                tools:text="dum, pes"/>

        <androidx.constraintlayout.widget.Barrier
                android:id="@+id/detailsBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="otherNounsHeader,otherNouns" />

        <ScrollView
                android:id="@+id/casesContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:scrollX="0dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:fillViewport="true"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:paddingBottom="@dimen/spacing_xxs"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/detailsBarrier"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/adViewContainer"
                app:layout_constraintVertical_chainStyle="packed">

            <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="bottom">

                <include
                        android:id="@+id/case1"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_content"
                        android:tag="0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case2"
                        app:num="@{0}"
                        app:plural="@{viewModel.cases[1][0]}"
                        app:singular="@{viewModel.cases[0][0]}"/>

                <include
                        android:id="@+id/case2"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case3"
                        app:num="@{1}"
                        app:plural="@{viewModel.cases[1][1]}"
                        app:singular="@{viewModel.cases[0][1]}"/>

                <include
                        android:id="@+id/case3"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case4"
                        app:num="@{2}"
                        app:plural="@{viewModel.cases[1][2]}"
                        app:singular="@{viewModel.cases[0][2]}"/>

                <include
                        android:id="@+id/case4"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="3"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case5"
                        app:num="@{3}"
                        app:plural="@{viewModel.cases[1][3]}"
                        app:singular="@{viewModel.cases[0][3]}"/>

                <include
                        android:id="@+id/case5"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case6"
                        app:num="@{4}"
                        app:plural="@{viewModel.cases[1][4]}"
                        app:singular="@{viewModel.cases[0][4]}"/>

                <include
                        android:id="@+id/case6"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="5"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case7"
                        app:num="@{5}"
                        app:plural="@{viewModel.cases[1][5]}"
                        app:singular="@{viewModel.cases[0][5]}"/>

                <include
                        android:id="@+id/case7"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="6"
                        android:layout_marginBottom="@dimen/spacing_sm_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:num="@{6}"
                        app:plural="@{viewModel.cases[1][6]}"
                        app:singular="@{viewModel.cases[0][6]}"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

        <!-- AdMob Banner Ad container - AdView created programmatically -->
        <FrameLayout
                android:id="@+id/adViewContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:minHeight="60dp"
                android:background="@color/colorSurfaceVariant"
                app:layout_constraintTop_toBottomOf="@id/casesContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>