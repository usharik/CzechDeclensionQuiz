<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurface">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:textColor="@color/colorOnSurface"
        android:layout_marginBottom="@dimen/spacing_xxl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideLine"
        android:text="@string/app_name" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/about_logo_guideline_offset" />

    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleX="1.5"
        android:scaleY="1.5"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="@string/app_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideLine" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/appVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appLogo"
        tools:text="Version 1.01-RC Debug" />

    <com.google.android.material.textview.MaterialTextView
            android:id="@+id/appDateOfBuild"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_content"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="@color/colorOnSurfaceVariant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/appVersion"
            tools:text="Date of build: 27.07.2018 15:07" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/subscriptionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_content"
        android:textAppearance="?attr/textAppearanceBody2"
        android:textColor="@color/colorOnSurfaceVariant"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appDateOfBuild"
        tools:text="Current plan: Premium" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/manageSubscription"
        style="@style/Widget.App.Button.Outlined.Modern"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_button_horizontal"
        android:layout_marginTop="@dimen/spacing_button_horizontal"
        android:layout_marginEnd="@dimen/spacing_button_horizontal"
        android:text="@string/premium_subscription"
        android:textSize="@dimen/text_size_body"
        android:visibility="gone"
        app:icon="@drawable/ic_star"
        app:iconPadding="@dimen/spacing_content"
        app:iconTint="@color/button_outline_stroke"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subscriptionStatus" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/rateApp"
        style="@style/Widget.App.Button.Gradient.Accent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_button_horizontal"
        android:layout_marginTop="@dimen/spacing_button_horizontal"
        android:layout_marginEnd="@dimen/spacing_button_horizontal"
        android:text="@string/rate_app"
        android:textSize="@dimen/text_size_body"
        app:icon="@drawable/ic_star"
        app:iconPadding="@dimen/spacing_content"
        app:iconTint="@color/button_text_on_gradient"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/manageSubscription" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/privacyPolicy"
        style="@style/Widget.App.Button.Outlined.Modern"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_button_horizontal"
        android:layout_marginTop="@dimen/spacing_md_large"
        android:layout_marginEnd="@dimen/spacing_button_horizontal"
        android:text="@string/privacy_policy"
        android:textSize="@dimen/text_size_body"
        app:icon="@drawable/ic_privacy_black_24dp"
        app:iconPadding="@dimen/spacing_content"
        app:iconTint="@color/button_outline_stroke"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rateApp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/testNotification"
        style="@style/Widget.App.Button.Outlined.Modern"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_button_horizontal"
        android:layout_marginTop="@dimen/spacing_md_large"
        android:layout_marginEnd="@dimen/spacing_button_horizontal"
        android:text="@string/test_notification"
        android:textSize="@dimen/text_size_body"
        android:visibility="gone"
        app:icon="@drawable/ic_notifications_black_24dp"
        app:iconPadding="@dimen/spacing_content"
        app:iconTint="@color/button_outline_stroke"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/privacyPolicy" />

</androidx.constraintlayout.widget.ConstraintLayout>
