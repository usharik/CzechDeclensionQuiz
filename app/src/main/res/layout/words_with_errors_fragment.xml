<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.usharik.app.fragment.WordsWithErrorsViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="@dimen/spacing_xxs"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_xxs"
        tools:context="com.usharik.app.MainActivity">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/headerCard"
            style="@style/Widget.App.SectionCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/flowScroll" />

        <ScrollView android:id="@+id/flowScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_xs"
            android:fillViewport="true"
            android:paddingStart="@dimen/spacing_xxs"
            android:paddingEnd="@dimen/spacing_xxs"
            android:paddingBottom="@dimen/spacing_sm"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guideLine">

            <com.usharik.app.widget.FlowLayout
                android:id="@+id/wordsWithErrorsFlow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_content">

            </com.usharik.app.widget.FlowLayout>
        </ScrollView>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideLine"
            android:layout_width="1dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.33"/>

        <ScrollView
            android:id="@+id/casesContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:fillViewport="true"
            android:paddingStart="@dimen/spacing_xxs"
            android:paddingEnd="@dimen/spacing_xxs"
            android:paddingBottom="@dimen/spacing_xxs"
            android:clipToPadding="false"
            android:scrollX="0dp"
            app:layout_constraintTop_toTopOf="@id/guideLine"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/adViewContainer"
            app:layout_constraintVertical_chainStyle="packed">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom">

                <include
                    android:id="@+id/case1"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_content"
                    android:tag="0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/case2"
                    app:num="@{0}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][0]}"
                    app:singular="@{viewModel.cases[0][0]}"/>

                <include
                    android:id="@+id/case2"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:tag="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/case3"
                    app:num="@{1}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][1]}"
                    app:singular="@{viewModel.cases[0][1]}"/>

                <include
                    android:id="@+id/case3"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:tag="2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/case4"
                    app:num="@{2}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][2]}"
                    app:singular="@{viewModel.cases[0][2]}"/>

                <include
                    android:id="@+id/case4"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:tag="3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/case5"
                    app:num="@{3}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][3]}"
                    app:singular="@{viewModel.cases[0][3]}"/>

                <include
                    android:id="@+id/case5"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:tag="4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/case6"
                    app:num="@{4}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][4]}"
                    app:singular="@{viewModel.cases[0][4]}"/>

                <include
                    android:id="@+id/case6"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:tag="5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/case7"
                    app:num="@{5}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][5]}"
                    app:singular="@{viewModel.cases[0][5]}"/>

                <include
                    android:id="@+id/case7"
                    layout="@layout/row_case"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:tag="6"
                    android:layout_marginBottom="@dimen/spacing_sm_large"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:num="@{6}"
                    app:switchOffAnimation="@{true}"
                    app:plural="@{viewModel.cases[1][6]}"
                    app:singular="@{viewModel.cases[0][6]}"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

        <!-- AdMob Banner Ad container - AdView created programmatically -->
        <FrameLayout
            android:id="@+id/adViewContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:minHeight="60dp"
            android:background="@color/colorSurfaceVariant"
            app:layout_constraintTop_toBottomOf="@id/casesContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
