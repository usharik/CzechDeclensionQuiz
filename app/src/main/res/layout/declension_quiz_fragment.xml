<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
                name="viewModel"
                type="com.usharik.app.fragment.DeclensionQuizViewModel"/>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/spacing_xxs"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_xxs"
            tools:context="com.usharik.app.MainActivity">

        <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerCard"
                style="@style/Widget.App.SectionCard"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/wordsRecyclerView" />

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_content"
                android:layout_marginStart="@dimen/spacing_xxs"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:text="@{viewModel.word}"
                android:textAppearance="@style/TextAppearance.App.Title"
                android:textSize="19sp"
                android:textColor="@color/colorOnSurface"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="kutil"/>

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/declensionType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xxs"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:text="@{@string/declension_pattern(viewModel.declensionType)}"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textSize="15sp"
                android:textColor="@color/colorOnSurface"
                app:layout_constraintBaseline_toBaselineOf="@id/word"
                app:layout_constraintStart_toEndOf="@id/word"
                app:layout_constraintEnd_toStartOf="@id/gender"
                tools:text="jako pán"/>

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_xxs"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:text="@{viewModel.gender}"
                android:textAppearance="@style/TextAppearance.App.Label"
                android:textSize="13sp"
                android:textColor="@color/colorOnSurfaceVariant"
                app:layout_constraintBaseline_toBaselineOf="@id/word"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="rod. m. neziv."/>

        <androidx.constraintlayout.widget.Barrier
                android:id="@+id/headerTextBottomBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="word,declensionType,gender" />

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/translation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:text="@{viewModel.translation}"
                android:textAppearance="@style/TextAppearance.App.Caption"
                android:textSize="12sp"
                android:textColor="@color/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="@id/word"
                app:layout_constraintEnd_toStartOf="@id/errorCounter"
                app:layout_constraintTop_toBottomOf="@id/headerTextBottomBarrier"
                tools:text="translation1, translation2, translation3, translation4, translation5, translation6, translation7"/>

        <com.google.android.material.textview.MaterialTextView
                android:id="@+id/errorCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xxs"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:text="@{viewModel.wrongAttemptsCounter}"
                android:textAppearance="@style/TextAppearance.App.Caption"
                android:textSize="11sp"
                android:textColor="@color/colorError"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="@id/translation"
                tools:text="1/5"/>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/wordsRecyclerView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/spacing_xs"
                android:paddingStart="@dimen/spacing_xxs"
                android:paddingEnd="@dimen/spacing_xxs"
                android:paddingBottom="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="true"
                app:layout_constraintTop_toBottomOf="@id/translation"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/guideLine" />

        <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideLine"
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.33"/>

        <ScrollView
                android:id="@+id/casesContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:fillViewport="true"
                android:paddingStart="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_xs"
                android:paddingBottom="@dimen/spacing_xs"
                android:clipToPadding="false"
                android:scrollX="0dp"
                app:layout_constraintTop_toTopOf="@id/guideLine"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/adViewContainer"
                app:layout_constraintVertical_chainStyle="packed">

            <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="bottom">

                <include
                        android:id="@+id/case1"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_content"
                        android:tag="0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case2"
                        app:num="@{0}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][0])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][0])}"/>

                <include
                        android:id="@+id/case2"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case3"
                        app:num="@{1}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][1])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][1])}"/>

                <include
                        android:id="@+id/case3"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case4"
                        app:num="@{2}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][2])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][2])}"/>

                <include
                        android:id="@+id/case4"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="3"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case5"
                        app:num="@{3}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][3])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][3])}"/>

                <include
                        android:id="@+id/case5"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case6"
                        app:num="@{4}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][4])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][4])}"/>

                <include
                        android:id="@+id/case6"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="5"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/case7"
                        app:num="@{5}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][5])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][5])}"/>

                <include
                        android:id="@+id/case7"
                        layout="@layout/row_case"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:tag="6"
                        android:layout_marginBottom="@dimen/spacing_sm_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:num="@{6}"
                        app:switchOffAnimation="@{viewModel.switchOffAnimation}"
                        app:plural="@{viewModel.getWordByIndex(viewModel.caseModels[1][6])}"
                        app:singular="@{viewModel.getWordByIndex(viewModel.caseModels[0][6])}"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

        <!-- AdMob Banner Ad container - AdView created programmatically -->
        <FrameLayout
                android:id="@+id/adViewContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:minHeight="60dp"
                android:background="@color/colorSurfaceVariant"
                app:layout_constraintTop_toBottomOf="@id/casesContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>